{
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "env": {
    "VITE_API_BASE": "https://stephenzao-biblesphere.hf.space/api"
  },
  "redirects": [
    {
      "source": "/film-studio",
      "destination": "https://stephenzao-biblesphere.hf.space/film-studio",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}