{
  "name": "emotion-sphere-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run i18n:fill",
    "build": "vite build",
    "i18n:fill": "node scripts/i18n_autoen_fill.mjs",
    "i18n:fill:dry": "node scripts/i18n_autoen_fill.mjs --dry-run",
    "preview": "vite preview",
    "preview:mobile": "vite preview --host 0.0.0.0 --port 4173",
    "test": "NODE_OPTIONS=--no-warnings vitest run",
    "test:watch": "NODE_OPTIONS=--no-warnings vitest",
    "test:coverage": "NODE_OPTIONS=--no-warnings vitest run --coverage",
    "attention:seed": "node scripts/attention/seed-attention-demo.mjs",
    "attention:reset-demo": "node scripts/attention/reset-attention-demo.mjs",
    "attention:audit:security": "node scripts/attention/audit-attention-security.mjs",
    "attention:audit:permissions": "node scripts/attention/audit-attention-permissions.mjs",
    "attention:audit:logs": "node scripts/attention/audit-attention-logs.mjs",
    "attention:smoke": "node scripts/attention/smoke-attention.mjs",
    "attention:release-report": "node scripts/attention/generate-attention-release-report.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.16.3",
    "@tanstack/react-query": "^5.62.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "postprocessing": "^6.36.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "zustand": "^5.0.3",
    "livekit-client": "^2.7.0",
    "@livekit/krisp-noise-filter": "^0.2.16",
    "mapbox-gl": "^3.9.0",
    "maplibre-gl": "^1.15.2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/mapbox": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^25.0.0",
    "vite": "^5.4.11",
    "vitest": "^1.6.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "@types/mapbox-gl": "^3.4.1"
  }
}
