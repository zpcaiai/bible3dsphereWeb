VITE_API_BASE=http://localhost:8000/api
VITE_MAP_PROVIDER=leaflet
VITE_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
VITE_CESIUM_TOKEN=
VITE_MAPLIBRE_STYLE=
VITE_HYMN_AUDIO_BASE=https://cdn.holiness.uk/hymns
VITE_BOOK_BASE=https://cdn.holiness.uk/ebook

# Attention Stewardship release controls. The shipped module defaults on;
# disable only for an intentional rollback.
VITE_ATTENTION_MODULE_ENABLED=true
VITE_ATTENTION_AI_ENABLED=true
VITE_ATTENTION_COMMUNITY_ENABLED=true
VITE_ATTENTION_GROUPS_ENABLED=true
VITE_ATTENTION_ADMIN_ENABLED=true
VITE_ATTENTION_E2E_MODE=false
VITE_ATTENTION_DEMO_SEED_ENABLED=false

# Mission OS experience gate. Backend authorization remains authoritative.
VITE_MISSION_OS_ENABLED=false

# Voice transcription is proxied through the backend:
# set DEEPGRAM_API_KEY on the backend service, not as a VITE_* browser variable.
